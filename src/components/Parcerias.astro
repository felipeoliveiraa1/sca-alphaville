---
import { Image } from 'astro:assets';
import { partners, contact } from '../data/site';

import countach from '../assets/logos/partners/countach-motors.jpg';
import viotto from '../assets/logos/partners/clinica-viotto.png';
import postalPrime from '../assets/logos/partners/postal-prime.png';
import postalParts from '../assets/logos/partners/postal-parts.png';
import postalDetail from '../assets/logos/partners/postal-detail.png';
import postalRacing from '../assets/logos/partners/postal-racing.png';
import postalMotors from '../assets/logos/partners/postal-motors.png';
import scaImoveis from '../assets/logos/partners/sca-imoveis.png';
import iguatemi from '../assets/logos/partners/iguatemi-alphaville.jpg';

const wa = `https://wa.me/${contact.whatsappDigits}`;

const partnerLogos = [
  { src: countach, name: 'Countach Motors', label: 'Countach Motors' },
  { src: postalMotors, name: 'Postal Motors', label: 'Postal Motors' },
  { src: viotto, name: 'Clínica Viotto Alphaville', label: 'Clínica Viotto' },
  { src: postalPrime, name: 'Postal Prime', label: 'Postal Prime' },
  { src: iguatemi, name: 'Iguatemi Alphaville', label: 'Iguatemi' },
  { src: postalDetail, name: 'Postal Detail', label: 'Postal Detail' },
  { src: scaImoveis, name: 'SCA Imóveis', label: 'SCA Imóveis' },
  { src: postalParts, name: 'Postal Parts', label: 'Postal Parts' },
  { src: postalRacing, name: 'Postal Racing', label: 'Postal Racing' },
];
---
<section class="par section" id="parcerias">
  <div class="container container--wide">
    <div class="par__head">
      <div>
        <p class="eyebrow" data-reveal="fade">{partners.eyebrow}</p>
        <h2 class="par__title" data-reveal>{partners.title}</h2>
      </div>
      <div class="par__intro" data-reveal style="--reveal-delay:120ms">
        <p class="par__body">{partners.body}</p>
        <a class="btn btn--outline-gold" href={wa} target="_blank" rel="noopener" aria-label="Seja Parceiro, falar no WhatsApp (abre em nova aba)">
          <span>Seja Parceiro</span><span class="btn__arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>

  <div class="container container--wide">
    <div class="par__wall" aria-label="Parceiros do Super Carros Alphaville">
      {partnerLogos.map((l, i) => (
        <span class="par__item" data-reveal style={`--reveal-delay:${i * 60}ms`}>
          <span class="par__badge"><Image src={l.src} alt={l.name} widths={[120, 240]} sizes="120px" quality={80} /></span>
          <span class="par__name">{l.label}</span>
        </span>
      ))}
    </div>
  </div>

  <div class="container container--wide">
    <div class="par__benefits" data-stagger="110">
      {partners.benefits.map((b, i) => (
        <article class="par__benefit">
          <span class="index-num">0{i + 1}</span>
          <h3 class="par__bname gold-text">{b.title}</h3>
          <p class="par__bbody">{b.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .par__head { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: clamp(2rem, 5vw, 5rem); align-items: end; margin-bottom: clamp(3rem, 6vw, 5rem); }
  .par__title { font-size: var(--fs-h2); margin-top: 1.4rem; line-height: 1.05; max-width: 18ch; }
  .par__body { color: var(--text-muted); font-size: var(--fs-lead); line-height: 1.5; margin-bottom: 2rem; }

  .par__wall {
    display: flex; flex-wrap: wrap; justify-content: center;
    gap: clamp(1.8rem, 3.5vw, 3.2rem) clamp(1.4rem, 3vw, 3rem);
    border-block: 1px solid var(--line);
    padding-block: clamp(2.6rem, 5vw, 4.2rem);
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }
  .par__item {
    flex: none; display: inline-flex; flex-direction: column; align-items: center; gap: 0.9rem;
    width: clamp(112px, 11vw, 142px);
  }
  .par__badge {
    width: clamp(88px, 8.5vw, 116px); aspect-ratio: 1;
    border-radius: 50%; overflow: hidden;
    border: 1px solid var(--line-strong);
    box-shadow: 0 0 0 5px var(--tint), 0 16px 38px -22px rgba(0,0,0,0.85);
    transition: border-color var(--dur-fast), box-shadow var(--dur-fast), transform var(--dur-mid) var(--ease-expo);
  }
  .par__badge :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }
  .par__name {
    font-size: 0.74rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-dim); text-align: center; white-space: nowrap; transition: color var(--dur-fast);
  }
  .par__item:hover .par__badge {
    border-color: var(--gold);
    box-shadow: 0 0 0 5px var(--tint-gold), 0 18px 42px -20px rgba(0,0,0,0.9);
    transform: translateY(-5px);
  }
  .par__item:hover .par__name { color: var(--gold); }

  .par__benefits { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.2rem, 2.5vw, 2rem); }
  .par__benefit {
    padding: clamp(1.6rem, 3vw, 2.4rem);
    border: 1px solid var(--line); background: var(--tint);
    transition: border-color var(--dur-fast), background var(--dur-fast), transform var(--dur-mid) var(--ease-expo);
  }
  .par__benefit:hover { border-color: var(--line-gold); background: var(--tint-gold); transform: translateY(-4px); }
  .par__bname { font-size: var(--fs-h4); margin: 1.2rem 0 0.8rem; }
  .par__bbody { color: var(--text-muted); line-height: 1.55; font-size: 0.98rem; }

  @media (max-width: 860px) {
    .par__head { grid-template-columns: 1fr; gap: 1.6rem; }
    .par__benefits { grid-template-columns: 1fr; }
  }
</style>
