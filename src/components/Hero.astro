---
import { Image } from 'astro:assets';
import heroImg from '../assets/images/lambo-fleet-formation.jpg';
import { hero, contact } from '../data/site';
const wa = `https://wa.me/${contact.whatsappDigits}`;
---
<section class="hero grain" id="top">
  <div class="hero__media" data-parallax="0.16">
    <Image
      src={heroImg}
      alt="Frota de supercarros do Super Carros Alphaville em formação na pista"
      class="media-cover hero__img"
      widths={[768, 1280, 1920, 2400]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      quality={82}
    />
    <video class="hero__video" autoplay muted loop playsinline preload="none" aria-hidden="true" tabindex="-1">
      <source data-src="/video/hero.webm" type="video/webm" />
      <source data-src="/video/hero.mp4" type="video/mp4" />
    </video>
  </div>
  <div class="hero__scrim"></div>
  <div class="hero__glow"></div>

  <div class="hero__content container container--wide">
    <p class="eyebrow hero__eyebrow" data-reveal="fade">{hero.eyebrow}</p>

    <h1 class="hero__title">
      {hero.titleLines.map((line, i) => (
        <span class="line-mask"><span style={`--reveal-delay:${140 + i * 120}ms`}>{line}</span></span>
      ))}
    </h1>

    <p class="hero__lead lead" data-reveal style="--reveal-delay:560ms">{hero.lead}</p>

    <div class="hero__actions" data-reveal style="--reveal-delay:680ms">
      <a class="btn hero__cta" href={wa} target="_blank" rel="noopener" aria-label={`${hero.ctaPrimary.label} — falar no WhatsApp (abre em nova aba)`}>
        <span>{hero.ctaPrimary.label}</span><span class="btn__arrow" aria-hidden="true">→</span>
      </a>
      <a class="hero__link" href={hero.ctaSecondary.href}>
        <span>{hero.ctaSecondary.label}</span>
        <span class="hero__link-line" aria-hidden="true"></span>
      </a>
    </div>
  </div>

  <a class="hero__scroll" href="#ecossistema" aria-label="Rolar para baixo">
    <span class="hero__scroll-label">Explorar</span>
    <span class="hero__scroll-line"><span></span></span>
  </a>

  <div class="hero__corner">
    <span class="facet" aria-hidden="true"></span>
    <span>Alphaville · Barueri — SP</span>
  </div>
</section>

<style>
  /* ============================================================
     SCA Hero — Monument in the Fold (synthesis)
     One governed column, jewel CTA, intentional scroll cue.
     Everything inside 100svh. Square / architectural. Gold accent.
     ============================================================ */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    /* top clears the ~80px fixed nav; bottom reserves the scroll-cue band */
    padding-top: clamp(5.5rem, 9vh, 7rem);
    padding-bottom: clamp(5.5rem, 11vh, 7.5rem);
    overflow: clip;
    isolation: isolate;
  }

  /* ---- Preserved media / video / scrim / glow layers ---- */
  .hero__media { position: absolute; inset: -8% 0; will-change: transform; z-index: 0; }
  .hero__img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 58%;
  }
  .hero__video {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center 58%;
    opacity: 0; transition: opacity 1.4s var(--ease-expo); pointer-events: none;
  }
  .hero.is-video-playing .hero__video { opacity: 1; }

  .hero__scrim {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    /* Lighter top so the nav reads; progressively deep base where the title,
       lead, CTAs and scroll cue live; left weight to seat the column. */
    background:
      linear-gradient(180deg,
        rgba(6,14,11,0.60) 0%,
        rgba(6,14,11,0.24) 28%,
        rgba(6,14,11,0.58) 64%,
        rgba(6,14,11,0.92) 88%,
        rgba(6,14,11,0.99) 100%),
      linear-gradient(90deg,
        rgba(6,14,11,0.80) 0%,
        rgba(6,14,11,0.36) 44%,
        rgba(6,14,11,0.04) 74%);
  }
  .hero__glow {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background:
      radial-gradient(64% 48% at 16% 80%, rgba(43,124,94,0.20), transparent 62%),
      radial-gradient(40% 30% at 84% 14%, rgba(198,161,91,0.07), transparent 70%);
  }

  /* ---- Content: one rem/vh-scaled flow, deliberate rhythm ---- */
  .hero__content {
    position: relative; z-index: 2; width: 100%;
    display: flex; flex-direction: column;
  }
  .hero__eyebrow {
    margin: 0 0 clamp(1rem, 2vh, 1.5rem);
    color: var(--champagne);
  }

  /* Right-sized monument: capped so 3 stacked lines never dominate the fold. */
  .hero__title {
    margin: 0 0 clamp(1.2rem, 2.4vh, 1.7rem);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.1rem, 1rem + 3.6vw, 3.6rem);
    line-height: 1.02;
    letter-spacing: var(--track-tight);
    text-transform: uppercase;
    color: var(--text-strong);
    max-width: 15ch;
    text-wrap: balance;
  }
  .hero__title .line-mask { display: block; }
  .hero__title .line-mask > span { padding-block: 0.05em; }
  /* Middle line = gold serif italic: the single editorial jewel-accent. */
  .hero__title .line-mask:nth-child(2) > span {
    color: var(--gold);
    font-style: italic;
    font-family: var(--font-serif);
    font-weight: 400;
    text-transform: none;
    letter-spacing: -0.01em;
  }

  .hero__lead {
    margin: 0 0 clamp(1.5rem, 2.8vh, 2.1rem);
    max-width: 46ch;
    color: var(--text);
    /* Slightly tighter than the global lead so it holds to ~2 lines in the fold. */
    font-size: clamp(1.05rem, 0.98rem + 0.4vw, 1.3rem);
    line-height: 1.5;
  }

  /* Actions: one filled jewel CTA + one quiet editorial link. */
  .hero__actions {
    display: flex; align-items: center; flex-wrap: wrap;
    gap: clamp(1.1rem, 2.4vw, 2rem);
  }
  .hero__cta { flex: none; }

  .hero__link {
    position: relative;
    display: inline-flex; align-items: center;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    font-weight: 600;
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    padding-block: 0.45rem;
    transition: color var(--dur-fast) var(--ease-quad);
  }
  .hero__link-line {
    position: absolute; left: 0; bottom: 0;
    width: 100%; height: 1px;
    background: var(--line-strong);
    overflow: hidden;
  }
  .hero__link-line::after {
    content: ""; position: absolute; inset: 0;
    background: var(--gold);
    transform: scaleX(0); transform-origin: left;
    transition: transform var(--dur-mid) var(--ease-expo);
  }
  .hero__link:hover { color: var(--gold-bright); }
  .hero__link:hover .hero__link-line::after,
  .hero__link:focus-visible .hero__link-line::after { transform: scaleX(1); }

  /* ---- Scroll cue: intentional, always-visible signal ---- */
  .hero__scroll {
    position: absolute; left: 50%; bottom: clamp(1.4rem, 3vh, 2rem);
    translate: -50% 0;
    z-index: 3;
    display: flex; flex-direction: column; align-items: center; gap: 0.7rem;
    color: var(--text-muted);
    transition: color var(--dur-fast) var(--ease-quad);
  }
  .hero__scroll:hover { color: var(--gold-bright); }
  .hero__scroll-label {
    font-family: var(--font-sans);
    font-size: 0.66rem;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    font-weight: 500;
  }
  .hero__scroll-line {
    display: block; width: 1px; height: clamp(40px, 6vh, 54px);
    background: var(--line-strong); position: relative; overflow: hidden;
  }
  .hero__scroll-line > span {
    position: absolute; top: 0; left: 0; width: 100%; height: 42%;
    background: linear-gradient(180deg, transparent, var(--gold));
    animation: hero-scroll-cue 2.2s var(--ease-inout) infinite;
  }
  @keyframes hero-scroll-cue {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(260%); }
  }

  /* ---- Corner location label (instrument-panel restraint) ---- */
  .hero__corner {
    position: absolute; right: var(--gutter); bottom: clamp(1.6rem, 3.2vh, 2.2rem);
    z-index: 3;
    display: flex; align-items: center; gap: 0.7rem;
    font-family: var(--font-sans);
    font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ---- Reduced motion: hold the cue still ---- */
  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-line > span { animation: none; transform: translateY(0); height: 100%; opacity: 0.7; }
    .hero__video { transition: none; }
  }

  /* ---- Short viewports: tighten rhythm, keep one-fold ---- */
  @media (max-height: 720px) {
    .hero { padding-top: 5.25rem; padding-bottom: 4.75rem; }
    .hero__eyebrow { margin-bottom: 0.9rem; }
    .hero__title { font-size: clamp(2rem, 3.2vw, 3.1rem); margin-bottom: 1rem; }
    .hero__lead { margin-bottom: 1.2rem; }
    .hero__scroll-line { height: 40px; }
  }

  /* ---- Tablet / small laptop ---- */
  @media (max-width: 1024px) {
    .hero__title { max-width: 14ch; }
  }

  /* ---- Mobile ---- */
  @media (max-width: 760px) {
    .hero {
      padding-top: clamp(5rem, 13vh, 6.5rem);
      padding-bottom: clamp(6rem, 15vh, 7.5rem);
      align-items: flex-end;
    }
    .hero__scrim {
      background:
        linear-gradient(180deg, rgba(6,14,11,0.52) 0%, rgba(6,14,11,0.28) 32%, rgba(6,14,11,0.80) 76%, rgba(6,14,11,0.98) 100%);
    }
    .hero__corner { display: none; }
    .hero__title { font-size: clamp(2.2rem, 9vw, 3rem); max-width: 13ch; }
    .hero__lead { font-size: 1.08rem; max-width: 40ch; }
    .hero__scroll { bottom: 1.6rem; }
  }

  @media (max-width: 480px) {
    .hero__actions { flex-direction: column; align-items: stretch; gap: 1.1rem; }
    .hero__actions .hero__cta { width: 100%; justify-content: center; }
    .hero__link { justify-content: center; align-self: stretch; }
    .hero__title { font-size: clamp(2rem, 11vw, 2.7rem); max-width: 100%; }
    .hero__lead { font-size: 1.02rem; }
  }
</style>

<script>
  // Hero background video: enhancement only. The poster <Image> is the LCP and shows
  // instantly; the video then loads/plays on desktop AND mobile (muted + playsinline),
  // skipped only under reduced-motion or the user's data-saver setting.
  const hero = document.querySelector<HTMLElement>('.hero');
  const video = hero?.querySelector<HTMLVideoElement>('video.hero__video');
  if (hero && video) {
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const saveData = (navigator as unknown as { connection?: { saveData?: boolean } }).connection?.saveData;
    if (!reduce && !saveData) {
      let any = false;
      video.querySelectorAll('source').forEach((s) => {
        if (s.dataset.src) { s.src = s.dataset.src; any = true; }
      });
      if (any) video.load();
      const play = () => { video.play().catch(() => {}); };
      video.addEventListener('canplay', () => { hero.classList.add('is-video-playing'); play(); }, { once: true });
      // Pause when the hero scrolls offscreen or the tab is hidden — saves battery/CPU.
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => { if (e.isIntersecting) play(); else video.pause(); }),
        { threshold: 0 }
      );
      io.observe(hero);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) video.pause();
        else if (hero.classList.contains('is-video-playing')) play();
      });
    }
  }
</script>
