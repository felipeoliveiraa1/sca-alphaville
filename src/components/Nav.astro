---
import Wordmark from './Wordmark.astro';
import { nav, contact } from '../data/site';
const wa = `https://wa.me/${contact.whatsappDigits}`;
---
<header class="nav" data-nav>
  <div class="nav__inner">
    <a class="nav__brand" href="#top" aria-label="Super Carros Alphaville — início" data-hover>
      <Wordmark class="nav__logo" />
    </a>

    <nav class="nav__links" aria-label="Navegação principal">
      {nav.map((item) => (
        <a class="nav__link link-underline" href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="nav__actions">
      <a class="btn nav__cta" href={wa} target="_blank" rel="noopener" aria-label="Seja Membro — falar no WhatsApp (abre em nova aba)">
        <span>Seja Membro</span>
        <span class="btn__arrow" aria-hidden="true">→</span>
      </a>
      <button class="nav__burger" data-menu-toggle aria-label="Abrir menu" aria-expanded="false" aria-controls="menu-mobile">
        <span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="menu" id="menu-mobile" data-menu>
    <nav class="menu__links" aria-label="Navegação">
      {nav.map((item, i) => (
        <a class="menu__link" href={item.href} style={`--i:${i}`}>
          <span class="menu__index">0{i + 1}</span>
          {item.label}
        </a>
      ))}
    </nav>
    <a class="btn menu__cta" href={wa} target="_blank" rel="noopener">
      <span>Seja Membro</span><span class="btn__arrow" aria-hidden="true">→</span>
    </a>
  </div>
</header>

<style>
  .nav {
    position: fixed; inset: 0 0 auto 0; z-index: var(--z-nav);
    transition: background var(--dur-fast) var(--ease-quad), border-color var(--dur-fast), backdrop-filter var(--dur-fast);
    border-bottom: 1px solid transparent;
  }
  .nav::before {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(180deg, rgba(6,14,11,0.65), transparent);
    opacity: 1; transition: opacity var(--dur-fast);
  }
  .nav.is-scrolled {
    background: var(--bg-glass);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    border-bottom-color: var(--line);
  }
  .nav.is-scrolled::before { opacity: 0; }

  .nav__inner {
    position: relative;
    display: flex; align-items: center; justify-content: space-between;
    gap: 2rem;
    max-width: var(--container-wide); margin-inline: auto;
    padding: clamp(1.2rem, 2.2vw, 2rem) var(--gutter);
  }
  .nav__brand { display: flex; align-items: center; color: var(--text-strong); transition: color var(--dur-fast); }
  .nav__brand:hover { color: var(--gold); }
  .nav__brand :global(svg) { height: clamp(20px, 2.4vw, 26px); width: auto; }

  .nav__links { display: flex; gap: clamp(1.4rem, 2.4vw, 2.6rem); }
  .nav__link {
    font-size: 0.78rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text); white-space: nowrap;
  }

  .nav__actions { display: flex; align-items: center; gap: 1rem; }
  .nav__cta { padding: 0.85em 1.5em; }

  .nav__burger { display: none; width: 44px; height: 44px; position: relative; margin-right: -10px; }
  .nav__burger span {
    position: absolute; left: 50%; height: 1.5px; width: 24px; background: var(--text-strong);
    transform: translateX(-50%);
    transition: top var(--dur-fast) var(--ease-expo), transform var(--dur-fast) var(--ease-expo), opacity var(--dur-fast);
  }
  .nav__burger span:nth-child(1) { top: 18px; }
  .nav__burger span:nth-child(2) { top: 26px; }

  /* Mobile menu overlay */
  .menu {
    position: fixed; inset: 0; z-index: calc(var(--z-nav) - 1);
    background: var(--bg);
    display: flex; flex-direction: column; justify-content: center; gap: 2.5rem;
    padding: var(--gutter);
    clip-path: inset(0 0 100% 0);
    transition: clip-path 0.7s var(--ease-expo);
    pointer-events: none;
  }
  .menu::after {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(80% 60% at 80% 10%, rgba(43,124,94,0.12), transparent 60%);
  }
  .menu__links { display: grid; gap: 0.4rem; position: relative; }
  .menu__link {
    display: flex; align-items: baseline; gap: 1rem;
    font-family: var(--font-display); font-size: clamp(2rem, 8vw, 3rem); font-weight: 500;
    color: var(--text-strong); letter-spacing: -0.02em; line-height: 1.1;
    opacity: 0; transform: translateY(16px) scale(0.97);
    transition: opacity 0.45s var(--ease-expo), transform 0.45s var(--ease-expo), color var(--dur-fast);
  }
  .menu__link:hover { color: var(--gold); }
  .menu__index { font-family: var(--font-sans); font-size: 0.8rem; color: var(--gold); letter-spacing: 0.1em; }
  .menu__cta { align-self: flex-start; position: relative; opacity: 0; transition: opacity 0.5s ease 0.3s; }

  /* open state */
  :global(body.menu-open) { overflow: hidden; }
  :global(body.menu-open) .menu { clip-path: inset(0 0 0 0); pointer-events: auto; }
  :global(body.menu-open) .menu__link { opacity: 1; transform: none; transition-delay: calc(0.14s + var(--i) * 0.035s); }
  :global(body.menu-open) .menu__cta { opacity: 1; }
  :global(body.menu-open) .nav__burger span:nth-child(1) { top: 22px; transform: translateX(-50%) rotate(45deg); }
  :global(body.menu-open) .nav__burger span:nth-child(2) { top: 22px; transform: translateX(-50%) rotate(-45deg); }

  @media (max-width: 1024px) {
    .nav__links { display: none; }
    .nav__cta { display: none; }
    .nav__burger { display: block; }
  }
</style>
