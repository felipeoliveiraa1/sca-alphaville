---
import { Image } from 'astro:assets';
import fleet from '../assets/images/lambo-fleet-formation.jpg';
import { membership, contact } from '../data/site';
const wa = `https://wa.me/${contact.whatsappDigits}`;
---
<section class="mem section" id="membro">
  <div class="mem__bg" aria-hidden="true">
    <div class="mem__bg-inner" data-parallax="0.08">
      <Image src={fleet} alt="" class="media-cover" widths={[768, 1280, 1920]} sizes="100vw" quality={70} loading="lazy" />
    </div>
  </div>
  <div class="mem__glow" aria-hidden="true"></div>
  <div class="container container--wide">
    <div class="mem__head">
      <p class="eyebrow eyebrow--center" data-reveal="fade">{membership.eyebrow}</p>
      <h2 class="mem__title" data-reveal>{membership.title}</h2>
      <p class="mem__body lead muted" data-reveal style="--reveal-delay:120ms">{membership.body}</p>
    </div>

    <div class="mem__cards" data-stagger="140">
      {membership.tiers.map((t, i) => (
        <article class={`mem__card ${i === 0 ? 'is-featured' : ''}`}>
          {i === 0 && <span class="mem__badge">Mais procurado</span>}
          <h3 class="mem__name">{t.name}</h3>
          <p class="mem__for">{t.for}</p>
          <ul class="mem__points">
            {t.points.map((p) => (
              <li><span class="facet" aria-hidden="true"></span>{p}</li>
            ))}
          </ul>
          <a class={`btn ${i === 0 ? '' : 'btn--ghost'} mem__cta`} href={wa} target="_blank" rel="noopener" aria-label={`${t.cta} — falar no WhatsApp (abre em nova aba)`}>
            <span>{t.cta}</span><span class="btn__arrow" aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </div>

    <p class="mem__fine" data-reveal>
      Os eventos não são abertos ao público — exclusivos para membros, famílias e empresas parceiras.
    </p>
  </div>
</section>

<style>
  .mem { position: relative; overflow: clip; }
  .mem__bg { position: absolute; inset: 0; z-index: 0; overflow: clip; }
  .mem__bg-inner { position: absolute; inset: -10% 0; will-change: transform; }
  .mem__bg::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(6,14,11,0.92) 0%, rgba(6,14,11,0.82) 45%, rgba(6,14,11,0.96) 100%);
  }
  .mem .container { position: relative; z-index: 1; }
  .mem__glow { position: absolute; inset: 0; pointer-events: none; z-index: 0; background: radial-gradient(55% 45% at 50% 0%, rgba(43,124,94,0.16), transparent 70%); }
  .mem__head { position: relative; text-align: center; max-width: 40ch; margin: 0 auto clamp(3rem, 6vw, 4.5rem); }
  .mem__title { font-size: var(--fs-h2); margin: 1.4rem 0 1.4rem; line-height: 1.06; }
  .mem__body { margin-inline: auto; }

  .mem__cards { position: relative; display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.2rem, 2.5vw, 2rem); max-width: 60rem; margin-inline: auto; }
  .mem__card {
    position: relative; padding: clamp(1.8rem, 3.5vw, 2.8rem);
    border: 1px solid var(--line); background: var(--bg-1);
    display: flex; flex-direction: column;
    transition: border-color var(--dur-fast), transform var(--dur-mid) var(--ease-expo);
  }
  .mem__card:hover { transform: translateY(-5px); border-color: var(--line-strong); }
  .mem__card.is-featured {
    border-color: var(--gold);
    background: linear-gradient(155deg, rgba(198,161,91,0.11), rgba(198,161,91,0.03) 55%, var(--bg-1));
    box-shadow: 0 28px 70px -44px rgba(198,161,91,0.5);
  }
  .mem__card.is-featured:hover { transform: translateY(-7px); box-shadow: 0 26px 64px -34px rgba(198,161,91,0.55); }
  .mem__badge {
    position: absolute; top: -1px; right: 1.5rem; transform: translateY(-50%);
    font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;
    background: var(--gold-grad); color: #1a1407; padding: 0.5em 1.05em; font-weight: 700;
  }
  .mem__name { font-size: var(--fs-h3); }
  .mem__for { color: var(--text-muted); margin: 0.8rem 0 1.8rem; line-height: 1.5; }
  .mem__points { display: grid; gap: 0.9rem; margin-bottom: 2.2rem; flex: 1; }
  .mem__points li { display: flex; align-items: center; gap: 0.9rem; color: var(--text); font-size: 0.96rem; }
  .mem__points .facet { flex: none; color: var(--gold); width: 0.5em; height: 0.5em; }
  .mem__cta { width: 100%; justify-content: center; }

  .mem__fine { text-align: center; margin-top: 2.5rem; font-size: 0.85rem; color: var(--text-dim); letter-spacing: 0.04em; }

  @media (max-width: 760px) {
    .mem__cards { grid-template-columns: 1fr; }
  }
</style>
