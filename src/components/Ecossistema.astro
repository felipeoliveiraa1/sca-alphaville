---
import { Image } from 'astro:assets';
import dreamCar from '../assets/images/dream-car-event.webp';
import { about } from '../data/site';
---
<section class="eco section" id="ecossistema">
  <div class="container container--wide eco__grid">
    <div class="eco__head">
      <p class="eyebrow" data-reveal="fade">{about.eyebrow}</p>
      <h2 class="eco__title" data-reveal>
        Mais que um clube, um <span class="serif gold-text">estilo de vida</span>, um selo de exclusividade e uma plataforma de crescimento.
      </h2>
    </div>

    <div class="eco__body">
      <div data-stagger="120">
        {about.body.map((p) => <p class="eco__p">{p}</p>)}
      </div>
      <div class="eco__sign" data-reveal style="--reveal-delay:200ms">
        <span class="facet" aria-hidden="true"></span>
        <span class="eco__sign-text">{about.signature}</span>
      </div>
    </div>
  </div>

  <div class="container container--wide">
    <figure class="eco__media" data-reveal="scale">
      <div class="eco__media-inner" data-parallax="0.1">
        <Image
          src={dreamCar}
          alt="Membros do Super Carros Alphaville reunidos no evento Dream Car, em São Roque"
          class="media-cover"
          widths={[768, 1280, 1920]}
          sizes="(max-width: 1560px) 100vw, 1560px"
          quality={80}
        />
      </div>
      <div class="eco__frame" aria-hidden="true"></div>
      <figcaption class="eco__cap">
        <span class="facet" aria-hidden="true"></span>
        <span>Comunidade SCA · Dream Car, São Roque</span>
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .eco { position: relative; }
  .eco__media { position: relative; margin-top: clamp(2.5rem, 6vw, 5rem); aspect-ratio: 16 / 7; overflow: clip; }
  .eco__media-inner { position: absolute; inset: -8% 0; will-change: transform; }
  .eco__media :global(img) { transition: transform var(--dur-slow) var(--ease-expo); }
  .eco__media:hover :global(img) { transform: scale(1.04); }
  .eco__frame { position: absolute; inset: 0; border: 1px solid var(--line-gold); pointer-events: none; }
  .eco__frame::before, .eco__frame::after {
    content: ''; position: absolute; width: 28px; height: 28px; border: 1px solid var(--gold);
  }
  .eco__frame::before { top: -1px; left: -1px; border-right: 0; border-bottom: 0; }
  .eco__frame::after { bottom: -1px; right: -1px; border-left: 0; border-top: 0; }
  .eco__cap {
    position: absolute; left: 1.2rem; bottom: 1.2rem; display: flex; align-items: center; gap: 0.6rem;
    font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text);
    background: rgba(6,14,11,0.5); backdrop-filter: blur(6px); padding: 0.6rem 0.9rem;
  }
  .eco__cap .facet { color: var(--gold); }
  @media (max-width: 900px) { .eco__media { aspect-ratio: 4 / 3; } }
  .eco__grid {
    display: grid; grid-template-columns: 1.15fr 0.85fr; gap: clamp(2rem, 6vw, 6rem); align-items: start;
  }
  .eco__title { font-size: var(--fs-h1); line-height: 1.0; max-width: 18ch; }
  .eco__body { padding-top: 0.6rem; }
  .eco__p { color: var(--text-muted); font-size: var(--fs-lead); line-height: 1.55; }
  .eco__p + .eco__p { margin-top: 1.4rem; }
  .eco__sign {
    display: flex; align-items: center; gap: 0.8rem; margin-top: 2.6rem;
    padding-top: 1.6rem; border-top: 1px solid var(--line-gold);
  }
  .eco__sign .facet { color: var(--gold); }
  .eco__sign-text { font-size: 0.82rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text); }

  @media (max-width: 900px) {
    .eco__grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .eco__title { font-size: clamp(2.2rem, 8vw, 3.4rem); }
  }
</style>
