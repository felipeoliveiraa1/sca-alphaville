---
import { Image } from 'astro:assets';
import networking from '../assets/images/members-networking.jpg';
import { essence } from '../data/site';
import Monogram from './Monogram.astro';
---
<section class="ess section grain" id="essencia">
  <div class="ess__bg" aria-hidden="true">
    <div class="ess__bg-inner" data-parallax="0.06">
      <Image src={networking} alt="" class="media-cover" widths={[768, 1280, 1920]} sizes="100vw" quality={70} loading="lazy" />
    </div>
  </div>
  <div class="ess__glow" aria-hidden="true"></div>
  <div class="ess__diamond" aria-hidden="true"><Monogram /></div>
  <div class="container container--wide">
    <div class="ess__head">
      <p class="eyebrow" data-reveal="fade">{essence.eyebrow}</p>
      <h2 class="ess__title" data-reveal>{essence.title}</h2>
    </div>

    <div class="ess__list">
      {essence.pillars.map((p) => (
        <article class="ess__row" data-reveal data-hover>
          <span class="ess__index">{p.index}</span>
          <h3 class="ess__name">{p.title}</h3>
          <p class="ess__body">{p.body}</p>
          <span class="ess__facet facet" aria-hidden="true"></span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .ess { position: relative; overflow: clip; }
  .ess__bg { position: absolute; inset: 0; z-index: 0; overflow: clip; }
  .ess__bg-inner { position: absolute; inset: -10% 0; will-change: transform; }
  .ess__bg::after {
    content: ''; position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(6,14,11,0.88) 0%, rgba(6,14,11,0.82) 50%, rgba(6,14,11,0.95) 100%),
      linear-gradient(90deg, rgba(6,14,11,0.85) 0%, rgba(6,14,11,0.45) 60%, rgba(6,14,11,0.30) 100%);
  }
  .ess .container { position: relative; z-index: 1; }
  .ess__glow {
    position: absolute; inset: 0; pointer-events: none; z-index: 0;
    background: radial-gradient(50% 60% at 88% 18%, rgba(43,124,94,0.16), transparent 62%);
  }
  .ess__diamond {
    position: absolute; top: clamp(1rem, 4vw, 4rem); right: clamp(-4rem, -2vw, 2rem);
    width: clamp(220px, 32vw, 460px); color: var(--gold);
    opacity: 0.10; pointer-events: none; z-index: 0;
    animation: ess-float 14s ease-in-out infinite;
  }
  .ess__diamond :global(svg) { width: 100%; height: auto; display: block; }
  @keyframes ess-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-18px) rotate(3deg); }
  }
  @media (prefers-reduced-motion: reduce) { .ess__diamond { animation: none; } }

  .ess__head { position: relative; max-width: 30ch; margin-bottom: clamp(2.5rem, 6vw, 4.5rem); }
  .ess__title { font-size: var(--fs-h2); margin-top: 1.4rem; line-height: 1.05; }

  .ess__list { position: relative; border-top: 1px solid var(--line); }
  .ess__row {
    position: relative;
    display: grid; grid-template-columns: auto 1fr 1.3fr auto; align-items: center;
    gap: clamp(1.5rem, 4vw, 4rem);
    padding-block: clamp(2rem, 4vw, 3rem);
    border-bottom: 1px solid var(--line);
    transition: padding-left var(--dur-mid) var(--ease-expo);
  }
  .ess__row::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
    background: var(--gold-grad); transform: scaleY(0); transform-origin: bottom;
    transition: transform var(--dur-mid) var(--ease-expo);
  }
  .ess__row:hover { padding-left: 1.6rem; }
  .ess__row:hover::before { transform: scaleY(1); transform-origin: top; }

  .ess__index { font-family: var(--font-display); font-size: 0.85rem; color: var(--gold); letter-spacing: 0.1em; align-self: start; padding-top: 0.4rem; }
  .ess__name { font-size: var(--fs-h3); transition: color var(--dur-fast); }
  .ess__row:hover .ess__name { color: var(--gold-bright); }
  .ess__body { color: var(--text-muted); font-size: 1.02rem; line-height: 1.6; max-width: 46ch; }
  .ess__facet { color: var(--gold); opacity: 0.4; transition: opacity var(--dur-fast), transform var(--dur-mid) var(--ease-expo); }
  .ess__row:hover .ess__facet { opacity: 1; transform: rotate(135deg); }

  @media (max-width: 860px) {
    .ess__row { grid-template-columns: auto 1fr; gap: 0.4rem 1.4rem; padding-block: 2rem; }
    .ess__body { grid-column: 2; }
    .ess__facet { display: none; }
    .ess__row:hover { padding-left: 0.8rem; }
  }
</style>
