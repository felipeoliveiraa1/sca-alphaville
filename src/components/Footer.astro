---
import { Image } from 'astro:assets';
import Wordmark from './Wordmark.astro';
import venue from '../assets/images/event-4anos-venue.jpg';
import { brand, contact, social, nav } from '../data/site';
const wa = `https://wa.me/${contact.whatsappDigits}`;
const year = 2026;
---
<footer class="footer" id="contato">
  <div class="footer__bg" aria-hidden="true">
    <div class="footer__bg-inner" data-parallax="0.06">
      <Image src={venue} alt="" class="media-cover" widths={[768, 1280]} sizes="100vw" quality={68} loading="lazy" />
    </div>
  </div>
  <div class="container--wide container">
    <div class="footer__cta" data-reveal>
      <p class="eyebrow">Acesso por convite</p>
      <h2 class="footer__headline">
        Entre para o universo<br /><span class="gold-text">Super Carros Alphaville.</span>
      </h2>
      <a class="btn footer__btn" href={wa} target="_blank" rel="noopener" aria-label="Falar no WhatsApp (abre em nova aba)">
        <span>Falar no WhatsApp</span><span class="btn__arrow" aria-hidden="true">→</span>
      </a>
    </div>

    <div class="hr footer__hr"></div>

    <div class="footer__grid">
      <div class="footer__col footer__col--brand">
        <p class="footer__label">Contato</p>
        <a class="footer__line link-underline" href={`tel:+${contact.whatsappDigits}`}>{contact.phoneDisplay}</a>
        <a class="footer__line link-underline" href={`mailto:${contact.email}`}>{contact.email}</a>
        <p class="footer__line muted">{brand.address}</p>
        <p class="footer__line muted">{contact.locations}</p>
      </div>

      <div class="footer__col">
        <p class="footer__label">Navegar</p>
        {nav.map((item) => <a class="footer__line link-underline" href={item.href}>{item.label}</a>)}
      </div>

      <div class="footer__col">
        <p class="footer__label">Conecte-se</p>
        <a class="footer__line link-underline" href={social.instagram} target="_blank" rel="noopener" aria-label="Instagram (abre em nova aba)">Instagram</a>
        <a class="footer__line link-underline" href={social.youtube} target="_blank" rel="noopener" aria-label="YouTube · Podcast (abre em nova aba)">YouTube · Podcast</a>
        <a class="footer__line link-underline" href={social.facebook} target="_blank" rel="noopener" aria-label="Facebook (abre em nova aba)">Facebook</a>
      </div>
    </div>
  </div>

  <!-- Monumental wordmark -->
  <a class="footer__monument" href={wa} target="_blank" rel="noopener" aria-label="Seja membro do Super Carros Alphaville (abre em nova aba)">
    <Wordmark class="footer__wordmark" />
  </a>

  <div class="footer__bottom container container--wide">
    <p class="muted">© {year} {brand.legalName} · CNPJ {brand.cnpj}</p>
    <div class="footer__legal">
      <a class="link-underline muted" href="#">Política de Privacidade</a>
      <a class="link-underline muted" href="#">Termos de Uso</a>
    </div>
  </div>
</footer>

<style>
  .footer { position: relative; padding-top: var(--section-y); overflow: clip; }
  .footer__bg { position: absolute; inset: 0; z-index: 0; overflow: clip; }
  .footer__bg-inner { position: absolute; inset: -8% 0; will-change: transform; }
  .footer__bg::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(6,14,11,0.95) 0%, rgba(6,14,11,0.90) 42%, rgba(6,14,11,0.97) 100%);
  }
  .footer > .container, .footer__monument, .footer__bottom { position: relative; z-index: 1; }
  .footer__cta { max-width: 40ch; padding-block: clamp(2rem, 5vw, 4rem); }
  .footer__headline {
    font-size: var(--fs-h2); margin-top: 1.4rem; margin-bottom: 2.2rem; line-height: 1.04;
  }
  .footer__btn { padding: 1.1em 2.1em; }
  .footer__hr { margin-block: clamp(2rem, 5vw, 4rem); }

  .footer__grid {
    display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: clamp(2rem, 5vw, 4rem);
  }
  .footer__label {
    font-size: var(--fs-eyebrow); letter-spacing: var(--track-label); text-transform: uppercase;
    color: var(--gold); margin-bottom: 1.4rem;
  }
  .footer__col { display: flex; flex-direction: column; gap: 0.8rem; align-items: flex-start; }
  .footer__line { font-size: 0.95rem; }

  .footer__monument {
    display: block; margin-top: clamp(3rem, 8vw, 7rem); padding-inline: var(--gutter);
    color: rgba(236,233,225,0.14);
    transition: color var(--dur-slow) var(--ease-expo);
  }
  .footer__monument :global(svg) { width: 100%; height: auto; display: block; }
  .footer__monument:hover { color: rgba(231,207,149,0.30); }

  .footer__bottom {
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
    padding-block: clamp(2rem, 4vw, 3rem); font-size: 0.8rem;
    border-top: 1px solid var(--line); margin-top: clamp(2rem, 6vw, 5rem);
  }
  .footer__legal { display: flex; gap: 1.6rem; }

  @media (max-width: 760px) {
    .footer__grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    .footer__col--brand { grid-column: 1 / -1; }
  }
</style>
